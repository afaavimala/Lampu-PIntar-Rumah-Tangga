name = "lampupintar"
main = "src/index.ts"
compatibility_date = "2026-06-07"
compatibility_flags = ["nodejs_compat"]
workers_dev = true

[assets]
directory = "../dashboard/dist"
binding = "ASSETS"

# Aman dicommit: hanya non-secret defaults.
# Jangan taruh credential/token/password di file ini.
# Secret harus diset via deploy script (`wrangler deploy --secrets-file`).
# Default vars di sini diselaraskan dengan root `.env.example`.
# Target production cloud default: lampupintar.afaavimala.workers.dev.
# Override via root `.env` + `npm run deploy:worker` jika perlu.
[vars]
COOKIE_SECURE = "false"
COOKIE_SAME_SITE = "Strict"
COOKIE_DOMAIN = ""
CORS_ORIGINS = "http://127.0.0.1:5173,http://localhost:5173"
MQTT_CLIENT_ID_PREFIX = "smartlamp-worker"
JWT_ACCESS_TTL_SEC = "900"
JWT_REFRESH_TTL_SEC = "2592000"
AUTH_LOGIN_RATE_LIMIT_MAX = "8"
AUTH_LOGIN_RATE_LIMIT_WINDOW_SEC = "60"
COMMAND_EXECUTE_RATE_LIMIT_MAX = "30"
COMMAND_EXECUTE_RATE_LIMIT_WINDOW_SEC = "60"
SEED_ADMIN_EMAIL = "admin@example.com"
SEED_SAMPLE_DEVICE_ID = "lampu-ruang-tamu"

[[d1_databases]]
binding = "DB"
database_name = "smartlamp_db"
database_id = "71be5235-fd72-4fb3-a646-b6a07e92b1d5"

[durable_objects]
bindings = [
  { name = "MQTT_GATEWAY", class_name = "MqttGatewayDurableObject" }
]

[[migrations]]
tag = "v1"
new_sqlite_classes = ["MqttGatewayDurableObject"]

[triggers]
crons = ["* * * * *"]
